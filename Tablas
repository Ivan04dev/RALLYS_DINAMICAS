CREATE TABLE ATC_RALLY_PODIOS(
    ID NUMBER(10) NOT NULL, 
    IDRALLY NUMBER(10),
    CATEGORIA VARCHAR2(150) NOT NULL,
    ORDEN NUMBER(3),
    ACTIVO CHAR(1),
    USUARIOCREO VARCHAR2(50),
    FECHACREACION DATE DEFAULT SYSDATE,
    USUARIOMODIFICO VARCHAR2(50),
    FECHAMODIFICACION DATE
);

CREATE SEQUENCE SEQ_ATC_RALLY_PODIOS
START WITH 1
INCREMENT BY 1
NOCACHE
NOCYCLE;

CREATE OR REPLACE TRIGGER TRG_ATC_RALLY_PODIOS
BEFORE INSERT
ON ATC_RALLY_PODIOS
FOR EACH ROW
BEGIN
    IF :NEW.ID IS NULL THEN
        SELECT SEQ_ATC_RALLY_PODIOS.NEXTVAL
        INTO :NEW.ID
        FROM DUAL;
    END IF;
    
    IF :NEW.FECHACREACION IS NULL THEN
        :NEW.FECHACREACION := SYSDATE;
    END IF;
    
END;
/
